# Sekura configuration template (.env format).
#
# Keys use the ASP.NET Core environment format: Section__Key=value
# (arrays as Section__0, Section__1, ...).
#
# Usage:
#   cp .env.template .env.prod    # production values (docker compose / App Service deploy)
#   cp .env.template .env.dev     # development values (start-linux.sh / start-win.ps1)
# Fill in the secrets. .env.prod and .env.dev are gitignored — never commit
# them once secrets are filled in.
#
# Values are read literally (no shell expansion), so '$' in password hashes
# needs no quoting or escaping. Multi-line values are not representable here;
# the mail body template falls back to the built-in default and is editable
# in the admin UI.

ASPNETCORE_ENVIRONMENT=Production

# --- Application ---
Application__Name=Sekura
Application__EnableHttpsRedirection=false
Application__PathBase=/
Application__TimeZoneId=UTC
Application__AuthenticationSessionTimeoutMinutes=60
Application__AuthenticationSlidingExpiration=true

# --- HTTP binding ---
# Leave commented for containers (the image binds http://+:8080) and for
# App Service (scripts/deploy-appservice.ps1 sets ASPNETCORE_URLS itself).
# Uncomment only when running bare-metal with the start scripts.
# ASPNETCORE_URLS=http://localhost:5099

# Host port published by docker compose (default 8080).
# SEKURA_PORT=8080

# --- Storage ---
# Backend: sqlite | sqlserver | postgresql | azure
Storage__Backend=sqlite
DatabaseResilience__MaxAttempts=3
DatabaseResilience__DelayMilliseconds=1000

# SQLite path: use /app/data/sekura.db in the container (named volume),
# App_Data/sekura.db for bare-metal runs.
SqliteStorage__ConnectionString=Data Source=App_Data/sekura.db
SqliteStorage__ApplyMigrationsOnStartup=true

SqlServerStorage__ConnectionString=
SqlServerStorage__ApplyMigrationsOnStartup=true

PostgresqlStorage__ConnectionString=
PostgresqlStorage__ApplyMigrationsOnStartup=true

# --- Azure backend (Storage__Backend=azure) ---
AzureStorage__KeyVault__VaultUri=
AzureStorage__KeyVault__TenantId=
AzureStorage__KeyVault__ClientId=
AzureStorage__KeyVault__ClientSecret=
AzureStorage__KeyVault__SecretPrefix=sekura
AzureStorage__TableAudit__ServiceSasUrl=
AzureStorage__TableAudit__TableName=auditlogs
AzureStorage__TableAudit__PartitionKey=audit

# --- Admin account ---
# Generate the hash with:
#   dotnet run --project ./sekura -- hash-admin-password --password '<password>'
AdminAuth__Username=admin
AdminAuth__PasswordHash=

# --- Encryption ---
# At least 15 characters (32+ recommended).
Encryption__Passphrase=ChangeThisEncryptionPassphraseToSomethingLongAndRandom

# --- Passkeys (WebAuthn) ---
Passkey__Enabled=false
Passkey__ServerDomain=sekura.example.com
Passkey__ServerName=Sekura
Passkey__Origins__0=https://sekura.example.com

# --- Login throttling ---
LoginThrottle__FailedAttemptLimit=5
LoginThrottle__PauseMinutes=15
LoginThrottle__FailureWindowMinutes=60

# --- Reverse proxy ---
ForwardedHeaders__Enabled=false
# ForwardedHeaders__KnownProxies__0=10.0.0.4
# ForwardedHeaders__KnownNetworks__0=10.0.0.0/8

# --- OIDC / Microsoft Entra ID ---
OidcAuth__Enabled=false
OidcAuth__Authority=https://login.example.com
OidcAuth__ClientId=sekura-app
OidcAuth__ClientSecret=
OidcAuth__LogTokensForTroubleshooting=false
OidcAuth__CallbackPath=/signin-oidc
OidcAuth__SignedOutCallbackPath=/signout-callback-oidc
OidcAuth__RequireHttpsMetadata=true
OidcAuth__Scopes__0=openid
OidcAuth__Scopes__1=profile
OidcAuth__Scopes__2=email
OidcAuth__GroupClaimType=groups
OidcAuth__AdminRoleName=Admin
OidcAuth__UserRoleName=User
OidcAuth__AdminGroups__0=<entra-group-id-for-admins>
OidcAuth__UserGroups__0=<entra-group-id-for-users>
OidcAuth__LocalLoginFallback=LoopbackOnly

# --- Shares ---
Share__DefaultExpiryHours=4
Share__CleanupIntervalSeconds=60

# --- Mail ---
Mail__SmtpHost=
Mail__Port=587
Mail__Username=
Mail__Password=
Mail__UseTls=true
Mail__SenderEmail=
Mail__SenderDisplayName=Sekura
Mail__AdminNotificationRecipients=
Mail__NotifyAdminsOnShareAccess=true
Mail__NotifyCreatorOnShareAccess=true
Mail__ShareAccessedSubjectTemplate=Share used: {{SharedUsername}} for {{RecipientEmail}}
# Mail__ShareAccessedBodyTemplate is multi-line and cannot live in a .env
# file; the built-in default applies and it is editable in the admin UI.

# --- Auditing / logging ---
ConsoleAuditLogging__Enabled=false
ConsoleAuditLogging__Level=INFO
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
Logging__LogLevel__Microsoft.EntityFrameworkCore=Error
AllowedHosts=*
