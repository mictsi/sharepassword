@model Sekura.ViewModels.TotpVerificationViewModel
@{
    ViewData["Title"] = "Authenticator Code";
}

<section class="auth-card">
    <div class="page-eyebrow">Verification</div>
    <h1 class="page-title">Login with authenticator app</h1>
    <p class="page-subtitle">Open the authenticator app on your phone and enter the current 6-digit code for @Model.Username.</p>

    <form asp-action="Totp" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger app-validation-summary" role="alert"></div>
        <div class="mb-3">
            <label asp-for="Code" class="form-label"></label>
            <input asp-for="Code" class="form-control" inputmode="numeric" autocomplete="one-time-code" maxlength="6" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
        <button type="submit" class="action-tile">
            <svg class="action-tile__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="7" y="2.5" width="10" height="19" rx="2" />
                <path d="M11 18.5h2" />
                <circle cx="10" cy="10.5" r="0.4" fill="currentColor" />
                <circle cx="12" cy="10.5" r="0.4" fill="currentColor" />
                <circle cx="14" cy="10.5" r="0.4" fill="currentColor" />
            </svg>
            <span class="action-tile__body">
                <span class="action-tile__title">Verify code</span>
                <span class="action-tile__hint">Check the code and complete your sign-in</span>
            </span>
            <svg class="action-tile__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m9 6 6 6-6 6" />
            </svg>
        </button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
