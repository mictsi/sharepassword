@model Sekura.ViewModels.SecondFactorSetupViewModel
@{
    ViewData["Title"] = "Set Up Second Factor";
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Security setup</div>
        <h1 class="page-title">Protect your account</h1>
        <p class="page-subtitle">The account @Model.Username requires a second verification step at sign-in. Choose the method you want to set up now — you can add the other one later from your profile.</p>
    </div>
</div>

<div class="admin-console-grid" aria-label="Second factor setup options">
    <a class="surface-card admin-console-card" href="@Url.ActionWithReturnUrl("PasskeySetup", Model.ReturnUrl)">
        <div>
            <svg class="second-factor-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="10" cy="7" r="4" />
                <path d="M3 21v-1a6 6 0 0 1 9.3-5" />
                <circle cx="17" cy="15" r="2.6" />
                <path d="M18.9 16.9 22 20" />
                <path d="m20.2 18.2 1.4-1.4" />
            </svg>
            <span class="page-eyebrow">Recommended</span>
            <h2 class="admin-console-card__title">Add passkey to your account</h2>
            <p class="admin-console-card__text">Sign in with your fingerprint, face, device screen lock, or a security key — nothing to type and nothing to lose. The passkey is stored by your device or password manager and works only on this site.</p>
        </div>
        <span class="admin-console-card__action">Add passkey</span>
    </a>

    <a class="surface-card admin-console-card" href="@Url.ActionWithReturnUrl("TotpSetup", Model.ReturnUrl)">
        <div>
            <svg class="second-factor-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="7" y="2.5" width="10" height="19" rx="2" />
                <path d="M11 18.5h2" />
                <circle cx="10" cy="10.5" r="0.4" fill="currentColor" />
                <circle cx="12" cy="10.5" r="0.4" fill="currentColor" />
                <circle cx="14" cy="10.5" r="0.4" fill="currentColor" />
            </svg>
            <span class="page-eyebrow">Authenticator app</span>
            <h2 class="admin-console-card__title">Add authenticator app to your account</h2>
            <p class="admin-console-card__text">Use an app such as Microsoft Authenticator or Google Authenticator on your phone. Scan a QR code once, then enter the 6-digit code the app shows each time you sign in.</p>
        </div>
        <span class="admin-console-card__action">Add authenticator app</span>
    </a>
</div>
