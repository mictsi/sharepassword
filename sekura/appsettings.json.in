{
  "Application": {
    "Name": "Sekura",
    "EnableHttpsRedirection": false,
    "PathBase": "/",
    "TimeZoneId": "UTC",
    "AuthenticationSessionTimeoutMinutes": 60,
    "AuthenticationSlidingExpiration": true
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5099"
      }
    }
  },
  "Storage": {
    "Backend": "sqlite"
  },
  "DatabaseResilience": {
    "MaxAttempts": 3,
    "DelayMilliseconds": 1000
  },
  "SqliteStorage": {
    "ConnectionString": "Data Source=App_Data/sekura.db",
    "ApplyMigrationsOnStartup": true
  },
  "SqlServerStorage": {
    "ConnectionString": "Server=tcp:sql.example.com,1433;Database=Sekura;Encrypt=True;TrustServerCertificate=False;User ID=sekura_app;Password=ChangeThisPassword!",
    "ApplyMigrationsOnStartup": true
  },
  "PostgresqlStorage": {
    "ConnectionString": "Host=localhost;Port=5432;Database=sekura;Username=sekura_app;Password=ChangeThisPassword!;SSL Mode=Require;Trust Server Certificate=false",
    "ApplyMigrationsOnStartup": true
  },
  "AzureStorage": {
    "KeyVault": {
      "VaultUri": "",
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "SecretPrefix": "sekura"
    },
    "TableAudit": {
      "ServiceSasUrl": "",
      "TableName": "auditlogs",
      "PartitionKey": "audit"
    }
  },
  "AdminAuth": {
    "Username": "admin",
    "PasswordHash": ""
  },
  "Passkey": {
    "Enabled": false,
    "ServerDomain": "sekura.example.com",
    "ServerName": "Sekura",
    "Origins": [ "https://sekura.example.com" ]
  },
  "LoginThrottle": {
    "FailedAttemptLimit": 5,
    "PauseMinutes": 15,
    "FailureWindowMinutes": 60
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "OidcAuth": {
    "Enabled": false,
    "Authority": "https://login.example.com",
    "ClientId": "sekura-app",
    "ClientSecret": "",
    "LogTokensForTroubleshooting": false,
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc",
    "RequireHttpsMetadata": true,
    "Scopes": [ "openid", "profile", "email" ],
    "GroupClaimType": "groups",
    "AdminRoleName": "Admin",
    "UserRoleName": "User",
    "AdminGroups": [ "<entra-group-id-for-admins>" ],
    "UserGroups": [ "<entra-group-id-for-users>" ],
    "LocalLoginFallback": "LoopbackOnly"
  },
  "Encryption": {
    "Passphrase": "ChangeThisEncryptionPassphraseToSomethingLongAndRandom"
  },
  "Share": {
    "DefaultExpiryHours": 4,
    "CleanupIntervalSeconds": 60
  },
  "Mail": {
    "SmtpHost": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "UseTls": true,
    "SenderEmail": "",
    "SenderDisplayName": "Sekura",
    "AdminNotificationRecipients": "",
    "NotifyAdminsOnShareAccess": true,
    "NotifyCreatorOnShareAccess": true,
    "ShareAccessedSubjectTemplate": "Share used: {{SharedUsername}} for {{RecipientEmail}}",
    "ShareAccessedBodyTemplate": "A secure share has been used.\n\nShare ID: {{ShareId}}\nCreated by: {{CreatedBy}}\nRecipient: {{RecipientEmail}}\nShared username: {{SharedUsername}}\nAccessed by: {{AccessedBy}}\nAccessed at: {{AccessedAt}}\nExpires at: {{ExpiresAt}}\nTime zone: {{TimeZoneId}}"
  },
  "ConsoleAuditLogging": {
    "Enabled": false,
    "Level": "INFO"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Error"
    }
  },
  "AllowedHosts": "*"
}
