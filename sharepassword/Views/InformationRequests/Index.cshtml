@model SharePassword.ViewModels.AdminInformationRequestDashboardViewModel
@{
    ViewData["Title"] = "Admin console - Information requests";

    string FormatStamp(DateTime value)
    {
        var local = ApplicationTime.ConvertUtcToApplicationTime(value);
        return $"{local:MMM dd, yyyy HH:mm}";
    }
}

<div class="page-header">
    <div>
        <div class="page-eyebrow">Admin console</div>
        <h1 class="page-title">Information requests</h1>
        <p class="page-subtitle">Create secure requests for external users, monitor responses, and revoke links when they are no longer needed.</p>
    </div>
    <div class="page-header__actions">
        <a class="btn btn-primary" asp-action="Create">Create information request</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
}

<div class="summary-grid">
    <section class="surface-card summary-card">
        <span class="page-eyebrow">Active</span>
        <span class="summary-card__value">@Model.ActiveCount</span>
        <span class="summary-card__meta">Requests that can still be updated.</span>
    </section>
    <section class="surface-card summary-card">
        <span class="page-eyebrow">Expiring soon</span>
        <span class="summary-card__value">@Model.ExpiringSoonCount</span>
        <span class="summary-card__meta">Expires within the next 24 hours.</span>
    </section>
    <section class="surface-card summary-card">
        <span class="page-eyebrow">Responses</span>
        <span class="summary-card__value">@Model.SubmittedCount</span>
        <span class="summary-card__meta">Requests with submitted information.</span>
    </section>
    <section class="surface-card summary-card">
        <span class="page-eyebrow">Revoked</span>
        <span class="summary-card__value">@Model.RevokedCount</span>
        <span class="summary-card__meta">Requests manually revoked.</span>
    </section>
</div>

<section class="surface-card">
    <form method="get" class="filter-toolbar">
        <div class="filter-toolbar__grid">
            <div class="filter-toolbar__field">
                <label for="requestSearch">Search</label>
                <input id="requestSearch" type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search user or creator" />
            </div>
            <div class="filter-toolbar__field">
                <label for="requestStatus">Status</label>
                <select id="requestStatus" name="status" class="form-select">
                    @foreach (var status in SharePassword.ViewModels.AdminInformationRequestStatusOption.AllValues)
                    {
                        <option value="@status" selected="@(status == Model.SelectedStatus)">@SharePassword.ViewModels.AdminInformationRequestStatusOption.GetLabel(status)</option>
                    }
                </select>
            </div>
        </div>

        <div class="filter-toolbar__actions">
            <button type="submit" class="btn btn-primary">Apply filters</button>
            @if (Model.HasFilters)
            {
                <a class="btn btn-outline-secondary" asp-action="Index">Clear filters</a>
            }
        </div>
    </form>
</section>

@if (!Model.HasRequests)
{
    <section class="surface-card empty-state">
        <h2 class="empty-state__title">No information requests created yet</h2>
        <p class="empty-state__text">Create a secure request to collect information from an external user.</p>
        <div class="empty-state__actions">
            <a class="btn btn-primary" asp-action="Create">Create information request</a>
        </div>
    </section>
}
else if (!Model.HasResults)
{
    <section class="surface-card empty-state">
        <h2 class="empty-state__title">No requests match the current filters</h2>
        <p class="empty-state__text">Adjust the status filter or clear the search to see the full list again.</p>
        <div class="empty-state__actions">
            <a class="btn btn-outline-secondary" asp-action="Index">Reset filters</a>
        </div>
    </section>
}
else
{
    <section class="current-shares">
        <div class="surface-card current-shares__header">
            <h2 class="surface-card__title">Current requests</h2>
            <p class="surface-card__subtitle">Showing @Model.Requests.Count of @Model.TotalVisibleRequests requests. Time zone: @ApplicationTime.TimeZoneId.</p>
        </div>

        <div class="surface-card share-list" role="list">
            <div class="share-list__head" aria-hidden="true">
                <span>Request</span>
                <span>Access mode</span>
                <span>Created on</span>
                <span>Expires on</span>
                <span>Status</span>
                <span></span>
            </div>

            @foreach (var item in Model.Requests)
            {
                <article class="share-list__row" role="listitem">
                    <div class="share-list__cell share-list__cell--share" data-label="REQUEST">
                        <span class="share-list__primary">@item.PartnerEmail</span>
                        <span class="share-list__meta">Created by @item.CreatedBy</span>
                    </div>

                    <div class="share-list__cell" data-label="ACCESS MODE">
                        <span class="status-badge status-badge--@item.AccessModeTone">@item.AccessModeLabel</span>
                    </div>

                    <div class="share-list__cell" data-label="CREATED ON">
                        <span class="share-list__value">@FormatStamp(item.CreatedAtUtc)</span>
                    </div>

                    <div class="share-list__cell" data-label="EXPIRES ON">
                        <span class="share-list__value">@FormatStamp(item.ExpiresAtUtc)</span>
                        @if (item.LastSubmittedAtUtc.HasValue)
                        {
                            <span class="share-list__meta">Updated @FormatStamp(item.LastSubmittedAtUtc.Value)</span>
                        }
                    </div>

                    <div class="share-list__cell share-list__cell--status" data-label="STATUS">
                        <div class="status-badge-list" aria-label="Request status">
                            @foreach (var statusBadge in item.StatusBadges)
                            {
                                <span class="status-badge status-badge--@statusBadge.Tone">@statusBadge.Label</span>
                            }
                        </div>
                    </div>

                    <div class="share-list__actions inline-actions">
                        <a class="btn btn-outline-secondary btn-sm" asp-action="Details" asp-route-id="@item.Id">View</a>
                        <form asp-action="Revoke" method="post" class="m-0" data-confirm="Revoke this information request? The link and access code will stop working immediately.">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">Revoke</button>
                        </form>
                    </div>
                </article>
            }
        </div>
    </section>
}
