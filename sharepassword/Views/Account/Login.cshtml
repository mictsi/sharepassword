@model SharePassword.ViewModels.AdminLoginViewModel
@{
    ViewData["Title"] = "Admin Login";
    var oidcEnabled = (bool?)ViewData["OidcEnabled"] == true;
}

<section class="auth-card">
    <div class="page-eyebrow">Admin</div>
    <h1 class="page-title">Admin login</h1>
    <p class="page-subtitle">Sign in to manage password shares.</p>

    @if (oidcEnabled)
    {
        <div class="inline-actions mb-3">
            <a class="btn btn-outline-secondary" asp-action="ExternalLogin">Sign in with Microsoft Entra ID</a>
        </div>
    }

    <form asp-action="Login" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger app-validation-summary" role="alert"></div>
        <div class="mb-3">
            <label asp-for="Username" class="form-label"></label>
            <input asp-for="Username" class="form-control" autocomplete="username" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Login</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
