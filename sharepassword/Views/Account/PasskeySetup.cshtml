@model SharePassword.ViewModels.PasskeySetupViewModel
@{
    ViewData["Title"] = "Set Up Passkey";
}

<section class="auth-card second-factor-action"
         data-passkey-register
         data-passkey-options-url="@Url.Action("PasskeyRegistrationOptions")"
         data-passkey-register-url="@Url.Action("PasskeyRegister")"
         data-passkey-return-url="@Model.ReturnUrl">
    <svg class="second-factor-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="10" cy="7" r="4" />
        <path d="M3 21v-1a6 6 0 0 1 9.3-5" />
        <circle cx="17" cy="15" r="2.6" />
        <path d="M18.9 16.9 22 20" />
        <path d="m20.2 18.2 1.4-1.4" />
    </svg>
    <div class="page-eyebrow">Security setup</div>
    <h1 class="page-title">Add passkey to your account</h1>
    <p class="page-subtitle">Register a passkey for @Model.Username. Give it a name you will recognize (like the device it lives on), then follow the browser prompt — your fingerprint, face, screen lock, or security key confirms it.</p>

    <form>
        @Html.AntiForgeryToken()
    </form>

    <div id="passkeyRegisterError" class="alert alert-danger d-none" role="alert"></div>

    <div class="mb-3">
        <label for="passkeyDisplayName" class="form-label">Passkey name</label>
        <input id="passkeyDisplayName" class="form-control" maxlength="128" placeholder="e.g. Work laptop" />
    </div>

    <div class="d-grid gap-3">
        <button type="button" id="passkeyRegisterButton" class="btn btn-primary">Create passkey and finish sign-in</button>
        <a class="btn btn-outline-primary" asp-action="TotpSetup" asp-route-returnUrl="@Model.ReturnUrl">Use an authenticator app instead</a>
    </div>
</section>

@section Scripts {
    <script src="~/js/passkey.js" asp-append-version="true"></script>
}
