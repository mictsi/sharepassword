@model SharePassword.ViewModels.InformationRequestAccessViewModel
@{
    ViewData["Title"] = Model.HasSubmittedResponse ? "Update Submitted Request" : "Submit Information";
    var expiresLocal = Model.ExpiresAtUtc.HasValue
        ? ApplicationTime.ConvertUtcToApplicationTime(Model.ExpiresAtUtc.Value)
        : (DateTimeOffset?)null;
    var submittedLocal = Model.LastSubmittedAtUtc.HasValue
        ? ApplicationTime.ConvertUtcToApplicationTime(Model.LastSubmittedAtUtc.Value)
        : (DateTimeOffset?)null;
    var submitLabel = Model.HasSubmittedResponse ? "Update submitted request" : "Open request";
}

<section class="public-card public-card--compact information-request-access">
    <div class="page-eyebrow">Secure request</div>
    <h1 class="page-title">@(Model.HasSubmittedResponse ? "Update submitted request" : "Submit information")</h1>
    @if (Model.HasSubmittedResponse)
    {
        <p class="page-subtitle">This request already has submitted information. Enter your access details to open the submitted content and update it before expiration.</p>
    }
    else if (Model.RequireOidcLogin)
    {
        <p class="page-subtitle">This request requires Microsoft Entra ID sign-in. Continue with the signed-in account that matches the partner email, then enter the access code.</p>
    }
    else
    {
        <p class="page-subtitle">Enter your email and access code to open the secure information request.</p>
    }

    @if (Model.HasSubmittedResponse || expiresLocal.HasValue)
    {
        <section class="surface-card surface-card--info compact-banner information-request-access__summary">
            @if (expiresLocal.HasValue)
            {
                <h2 class="surface-card__title">Available until @($"{expiresLocal.Value:MMM dd, yyyy HH:mm}")</h2>
                <p class="surface-card__subtitle">Time zone: @ApplicationTime.TimeZone.DisplayName (@ApplicationTime.TimeZoneId)</p>
            }
            @if (submittedLocal.HasValue)
            {
                <p class="surface-card__subtitle">Last submitted @($"{submittedLocal.Value:MMM dd, yyyy HH:mm}").</p>
            }
        </section>
    }

    <form asp-action="Access" method="post" class="mt-4">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger app-validation-summary" role="alert"></div>
        <input asp-for="Token" type="hidden" />
        <input asp-for="RequireOidcLogin" type="hidden" />

        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" maxlength="256" readonly="@(Model.RequireOidcLogin ? "readonly" : null)" autocomplete="email" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Code" class="form-label"></label>
            <input asp-for="Code" class="form-control" maxlength="15" autocomplete="one-time-code" autocapitalize="none" spellcheck="false" />
            <div class="form-text">15 characters. Case-sensitive.</div>
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">@submitLabel</button>
    </form>

    <p class="public-card__trust">Submitted information is deleted after expiration or revocation.</p>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}